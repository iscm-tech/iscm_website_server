{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "target": "ES2023",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "config": ["./config.ts"]
    }
  },
  "files": ["src/type.d.ts"],
  "include": ["src/**/*", "config.ts"]
}
